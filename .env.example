# 飞书应用配置
FEISHU_APP_ID=cli_xxxxxxxxxxxx
FEISHU_APP_SECRET=xxxxxxxxxxxx
FEISHU_APP_TOKEN=bascnxxxxxxxxxxxxxxxxxxxx
FEISHU_TYPE_TABLE_ID=tblTypexxxxxxxx
FEISHU_CONTENT_TABLE_ID=tblContentxxxxx
FEISHU_DETAIL_TABLE_ID=tblDetailxxxxxx
FEISHU_RECORD_TABLE_ID=tblRecordxxxxxx

# 飞书部门ID（open_department_id格式，如 od-xxxx，用于获取部门成员列表）
# 获取方式：打开如下地址：https://open.feishu.cn/document/directory-v1/department/mget，右侧点击“快速复制 open_department_id”，选择要看id的部门，确定，即可复制。
FEISHU_DEPARTMENT_ID=od-xxxxxxxxxxxxxxxx

# 服务端口配置（默认3001，如需修改请同时更新 NEXTAUTH_URL 和 FEISHU_REDIRECT_URI）
PORT=3001

# OAuth回调配置（端口修改时请同步更新）
NEXTAUTH_URL=http://localhost:3001
FEISHU_REDIRECT_URI=http://localhost:3001/auth/callback

# Session密钥（生成方式: openssl rand -base64 32）
SESSION_SECRET=your-random-secret-key-here

# 飞书API域名（中国版用 open.feishu.cn，国际版用 open.larksuite.com）
FEISHU_API_BASE_URL=https://open.feishu.cn

# 环境
NODE_ENV=development
